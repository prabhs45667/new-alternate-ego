# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   usually handled by the user. Everything else can be ignored.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files are meant to be committed.
#   If you truly want to ignore them, uncomment the following line:
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is meant to be committed.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is meant to be committed.
# pdm.lock
#   pdm envs are also ignored by default
.pdm-python

# PEP 582; used by e.g. github.com/davidhalter/jedi
__pypackages__/

